{
  "name": "nestjs-leak-guard",
  "version": "0.0.1",
  "description": "Static analysis CLI to detect data-leak risk patterns in NestJS code",
  "keywords": ["nestjs", "security", "static-analysis", "data-leak", "tenant", "linter"],
  "author": "Jinyeong Jung",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jinyeong-jung/nestjs-leak-guard.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nestjs-leak-guard": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "rm -rf dist",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "node-sql-parser": "^4.18.0",
    "ts-morph": "^21.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.7.0"
  }
}
